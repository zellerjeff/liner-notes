# Secret used to sign session tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Demo login (name-only sign-in). Enabled automatically in local dev when Google
# isn't configured; set to 1 to force-enable, leave unset/0 in production.
ALLOW_DEMO_LOGIN=0

# --- Google sign-in (see README) ---
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Database ---
# Local dev: leave unset to use a SQLite file at data/linernotes.db.
# Production (Vercel): set both from your Turso database.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Optional: official Spotify API (better metadata for huge playlists) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
